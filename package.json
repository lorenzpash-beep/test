{
  "name": "dnd-homebrew-pdfer",
  "version": "1.0.0",
  "main": "main.js",
  "engines": {
    "node": ">=26.1.0"
  },
  "scripts": {
    "electron": "electron .",
    "build": "cd client && npm run build",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0",
    "fs-extra": "^11.2.0",
    "pdf-parse": "^1.1.1",
    "puppeteer": "^22.0.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.dnd.homebrew.pdfer",
    "files": [
      "client/build/**/*",
      "server/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable"
    }
  }
}
